{
  "name": "invezgo-mcp",
  "version": "1.0.0",
  "main": "dist/server.js",
  "license": "ISC",
  "scripts": {
    "build": "tsc --build --verbose tsconfig.build.json && tsc-alias -p tsconfig.json",
    "start": "node ./dist/server.js --http",
    "dev": "ts-node-dev --project tsconfig.dev.json -r tsconfig-paths/register --transpile-only --respawn --exit-child src/server.ts --http",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "mcpb:validate": "npx @anthropic-ai/mcpb validate .",
    "mcpb:pack": "yarn build && node scripts/build-mcpb.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.17.1",
    "@toon-format/toon": "0.8.0",
    "fastmcp": "3.13.0",
    "zod": "4.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@eslint/json": "^0.13.1",
    "@swc/core": "^1.13.3",
    "@types/node": "^24.2.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "prettier": "^3.6.2",
    "ts-node-dev": "2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.39.0"
  }
}
